---
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-col" style="max-width:280px">
        <a class="logo" href="/#top" style="margin-bottom:14px" aria-label="SiteStac home"><img src="/logo.png" alt="SiteStac" class="logo-img" width="200" height="100" /></a>
        <p style="color:var(--ink-soft);font-size:.95rem">Websites built block by block for local businesses. Start with a landing page, stack on what you need.</p>
      </div>
      <div class="foot-col"><h4>Build</h4>
        <a href="/#stak">The Stak</a><a href="/#pricing">Pricing</a><a href="/blog">Blog</a>
      </div>
      <div class="foot-col"><h4>Blocks</h4>
        <a href="/#stak">Landing pages</a><a href="/#stak">Blogs</a><a href="/#stak">SEO</a><a href="/#stak">Hosting &amp; care</a>
      </div>
      <div class="foot-col"><h4>Get started</h4>
        <a href="/#start">Free preview</a><a href="mailto:hello@sitestac.com">hello@sitestac.com</a>
      </div>
    </div>
    <div class="wordmark" aria-hidden="true">SiteStac</div>
    <div class="foot-bottom">
      <span>© {year} SiteStac. All rights reserved.</span>
