---
import Base from "../layouts/Base.astro";
import Brick from "../components/Brick.astro";
import Icon from "../components/Icon.astro";
---
<Base>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-copy reveal in">
        <span class="eyebrow">● Built for local businesses</span>
        <h1>Grow your brand<br /><span class="hl">block by block.</span></h1>
        <p class="lede">We design a beautiful one-page site for your business — then you stack on exactly what you need. No bloat. No long contracts.</p>
        <div class="hero-cta">
          <a class="btn" href="#start" data-magnetic>Get a free preview</a>
          <a class="btn ghost" href="#stak">See the blocks</a>
        </div>
        <div class="hero-note"><span class="dot"></span> See your site before you pay a cent.</div>
      </div>
      <div class="stage" aria-hidden="true">
        <div class="stack">
          <Brick color="pink">Content</Brick>
          <Brick color="orange">Hosting &amp; care</Brick>
          <Brick color="green">SEO</Brick>
          <Brick color="purple">Blog</Brick>
          <Brick color="teal">Landing page</Brick>
          <Brick color="blue" base>SiteStac</Brick>
        </div>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee" aria-hidden="true">
    <div class="track">
      <span>Landing pages</span><span>Blogs</span><span>SEO</span><span>Hosting</span><span>Lead generation</span><span>Social</span><span>Content</span><span>You own it</span>
      <span>Landing pages</span><span>Blogs</span><span>SEO</span><span>Hosting</span><span>Lead generation</span><span>Social</span><span>Content</span><span>You own it</span>
    </div>
  </div>

  <!-- THE STAK -->
  <section class="block" id="stak">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="kicker"><span class="idx">01</span> The Stak</span>
        <h2>Start with one block. Add more anytime.</h2>
        <p>Every site starts with a stunning landing page. Need a blog next month? Want SEO or social? Snap on another block — your site grows with you.</p>
      </div>
      <div class="stak-wrap">
        <div class="stak-col reveal" id="stakBricks">
          <Brick color="pink" data-title="Content creation" data-desc="We craft the words and visuals that sell — sharp headlines, clear service descriptions, and polished photos so your business looks its best everywhere.">Content creation</Brick>
          <Brick color="purple" data-title="Blog & updates" data-desc="A simple blog with an easy login. Post news, offers, and articles yourself — no code — to keep customers coming back and give Google fresh reasons to rank you.">Blog &amp; updates</Brick>
          <Brick color="orange" data-title="Hosting & maintenance" data-desc="Secure, lightning-fast hosting with SSL and DDoS protection built in. We handle updates, backups, and uptime so your site just works — you never think about it.">Hosting &amp; maintenance</Brick>
          <Brick color="green" data-title="SEO & local search" data-desc="Get found by nearby customers. We optimize your pages and Google Business Profile so you show up when people search for what you offer.">SEO &amp; local search</Brick>
          <Brick color="teal" data-title="Lead generation" data-desc="Turn visitors into customers with click-to-call buttons, smart contact forms, and instant booking wired straight to your inbox or phone.">Lead generation</Brick>
          <Brick color="red" data-title="Social media" data-desc="Keep your social presence consistent and on-brand, connected right into your site so every post points back to you.">Social media</Brick>
          <Brick color="blue" base class="stak-base" data-title="Landing page" data-desc="The foundation every site starts on — a fast, beautiful one-page site with your story, services, and one clear call to action that turns visitors into customers.">Landing page</Brick>
        </div>
        <div class="stak-text reveal" id="stakText">
          <span class="stak-hint"><Icon name="pointer" size={15} /> Tap any block to see what it does</span>
          <h3>One foundation. Endless add-ons.</h3>
          <p>Your landing page is the base brick — fast, modern, and built to convert visitors into customers. Everything else stacks on top, only when you want it.</p>
          <ul>
            <li><span class="chk"><Icon name="check" size={14} /></span><span><b>You only pay for blocks you use.</b> No bundles you'll never touch.</span></li>
            <li><span class="chk"><Icon name="check" size={14} /></span><span><b>Add a blog with a simple login.</b> Post updates yourself, no code.</span></li>
            <li><span class="chk"><Icon name="check" size={14} /></span><span><b>Secure, lightning-fast hosting.</b> SSL and DDoS protection included.</span></li>
            <li><span class="chk"><Icon name="check" size={14} /></span><span><b>Want to own it outright?</b> We hand you the keys, one-time.</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="block" id="pricing">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="kicker"><span class="idx">02</span> Pricing</span>
        <h2>Pick your stack.</h2>
        <p>Simple, transparent pricing. Every site is different, so these are starting points — your final price depends on the stack you build.</p>
      </div>
      <div class="tiers">
        <div class="tier t-blue reveal">
          <span class="cap"></span><span class="pill">Starter Brick</span>
          <h3>One-Page</h3>
          <div class="price">From $849<small> + $150/mo</small></div>
          <p class="desc">A beautiful single landing page that converts.</p>
          <ul>
            <li><span class="d">▪</span> Custom one-page design</li>
            <li><span class="d">▪</span> Mobile-perfect &amp; fast</li>
            <li><span class="d">▪</span> Secure hosting + SSL</li>
            <li><span class="d">▪</span> Contact / booking button</li>
          </ul>
          <a class="btn ghost" href="#start">Start here</a>
        </div>
        <div class="tier t-pink feat reveal">
          <span class="cap"></span><span class="feat-tag">Popular</span><span class="pill">Cornerstone</span>
          <h3>3-Page Site</h3>
          <div class="price">From $1,499<small> + $200/mo</small></div>
          <p class="desc">Three pages plus a blog you control.</p>
          <ul>
            <li><span class="d">▪</span> Everything in One-Page</li>
            <li><span class="d">▪</span> Up to 3 pages</li>
            <li><span class="d">▪</span> Blog with easy login</li>
            <li><span class="d">▪</span> Basic SEO setup</li>
          </ul>
          <a class="btn" href="#start">Build my site</a>
        </div>
        <div class="tier t-orange reveal">
          <span class="cap"></span><span class="pill">Tower</span>
          <h3>Multi-Page</h3>
          <div class="price">From $1,899<small> + $200/mo</small></div>
          <p class="desc">More than three pages, built to rank.</p>
          <ul>
            <li><span class="d">▪</span> Everything in Cornerstone</li>
            <li><span class="d">▪</span> More than 3 pages</li>
            <li><span class="d">▪</span> Full SEO + blog program</li>
            <li><span class="d">▪</span> Priority edits</li>
          </ul>
          <a class="btn ghost" href="#start">Go big</a>
        </div>
      </div>

      <!-- ADD-ONS -->
      <div class="addons reveal">
        <h3 class="addons-title">Stack on add-ons</h3>
        <p class="addons-sub">Bolt any of these onto any plan whenever you're ready. <em>(Pricing quoted per project.)</em></p>
        <div class="addon-grid">
          <div class="addon b-pink"><span class="studs" aria-hidden="true"><i></i><i></i><i></i><i></i></span><span class="addon-dot"><Icon name="share" size={22} /></span><div class="addon-body"><b>Social media setup</b><span>Profiles built and branded, wired back to your site.</span></div></div>
          <div class="addon b-purple"><span class="studs" aria-hidden="true"><i></i><i></i><i></i><i></i></span><span class="addon-dot"><Icon name="mappin" size={22} /></span><div class="addon-body"><b>Google Business setup</b><span>Get found in local + maps search and start collecting reviews.</span></div></div>
          <div class="addon b-orange"><span class="studs" aria-hidden="true"><i></i><i></i><i></i><i></i></span><span class="addon-dot"><Icon name="pencil" size={22} /></span><div class="addon-body"><b>Monthly blog updates</b><span>Fresh SEO posts written and published for you each month.</span></div></div>
          <div class="addon b-green"><span class="studs" aria-hidden="true"><i></i><i></i><i></i><i></i></span><span class="addon-dot"><Icon name="palette" size={22} /></span><div class="addon-body"><b>Logo &amp; branding</b><span>A clean logo and color set so everything looks consistent.</span></div></div>
          <div class="addon b-teal"><span class="studs" aria-hidden="true"><i></i><i></i><i></i><i></i></span><span class="addon-dot"><Icon name="star" size={22} /></span><div class="addon-body"><b>Review generation</b><span>Automated review requests to grow your reputation.</span></div></div>
          <div class="addon b-blue"><span class="studs" aria-hidden="true"><i></i><i></i><i></i><i></i></span><span class="addon-dot"><Icon name="mail" size={22} /></span><div class="addon-body"><b>Email &amp; domain setup</b><span>Custom domain and professional email, configured for you.</span></div></div>
        </div>
        <span class="addons-tag">More add-ons available — just ask.</span>
      </div>
    </div>
  </section>

  <!-- WORK -->
  <section class="block" id="work" style="background:linear-gradient(180deg,rgba(243,246,251,.9),rgba(255,255,255,.5));border-block:1px solid var(--line)">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="kicker"><span class="idx">04</span> Work</span>
        <h2>Built block by block.</h2>
        <p>A taste of the kinds of sites we build. <em>(Swap these for your real client previews.)</em></p>
      </div>
      <div class="work-grid">
        <a class="card reveal" href="#start">
          <div class="thumb" style="background:linear-gradient(140deg,var(--teal),var(--teal-d))"><span class="meta">Landing page</span>Greenline Lawn Co.</div>
          <div class="body"><h3>Greenline Lawn Co.</h3><p>One-page site with instant quote button.</p></div>
        </a>
        <a class="card reveal" href="#start">
          <div class="thumb" style="background:linear-gradient(140deg,var(--pink),var(--pink-d))"><span class="meta">Landing + Blog</span>Maple &amp; Thread</div>
          <div class="body"><h3>Maple &amp; Thread</h3><p>Boutique site with a self-serve blog.</p></div>
        </a>
        <a class="card reveal" href="#start">
          <div class="thumb" style="background:linear-gradient(140deg,var(--orange),var(--orange-d))"><span class="meta">Multi-page</span>Apex HVAC</div>
          <div class="body"><h3>Apex HVAC</h3><p>Service pages, reviews and lead capture.</p></div>
        </a>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="block">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="kicker"><span class="idx">04</span> Why SiteStac</span>
        <h2>Beautiful is just the base brick.</h2>
      </div>
      <div class="trust">
        <div class="t reveal">
          <div class="ic" style="background:linear-gradient(180deg,var(--blue-l),var(--blue-d))"><Icon name="lock" size={26} /></div>
          <h3>Secure by default</h3>
          <p>Every site ships with SSL, DDoS protection and a tiny attack surface — far safer than a typical WordPress install.</p>
        </div>
        <div class="t reveal">
          <div class="ic" style="background:linear-gradient(180deg,#4fc96e,var(--green-d))"><Icon name="zap" size={26} /></div>
          <h3>Fast &amp; effortless</h3>
          <p>Pages load in a blink and you never touch the tech. Want changes? Send a message — we handle it.</p>
        </div>
        <div class="t reveal">
          <div class="ic" style="background:linear-gradient(180deg,#ffa642,var(--orange-d))"><Icon name="key" size={26} /></div>
          <h3>You can own it</h3>
          <p>Stay month-to-month or buy your site outright. No lock-in, no hostage situations. It's your business.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" id="start">
    <div class="wrap">
      <div class="box">
        <Brick color="pink" class="floatbrick" studs={2}>SEO</Brick>
        <Brick color="orange" class="floatbrick" studs={2}>Blog</Brick>
        <h2>Ready to stack?</h2>
        <p>Send us your Google Business Profile and get a free preview of your new site — no commitment, no credit card.</p>
        <a class="btn" href="mailto:hello@sitestac.com?subject=Free%20site%20preview&body=Here's%20my%20Google%20Business%20Profile%20link%3A%20">Get my free preview</a>
        <div style="margin-top:18px;opacity:.85;font-size:.95rem">or email <b>hello@sitestac.com</b></div>
      </div>
    </div>
  </section>

  <!-- BUILD YOUR STACK — floating cart button -->
  <button class="cart-fab cart-open" type="button" aria-haspopup="dialog"><Icon name="layers" size={18} /> Build your stack</button>

  <!-- BUILD YOUR STACK — cart modal -->
  <div class="cart-overlay" id="cartOverlay" aria-hidden="true">
    <div class="cart-modal" role="dialog" aria-modal="true" aria-label="Build your stack">
      <button class="cart-close" id="cartClose" type="button" aria-label="Close"><Icon name="x" size={20} /></button>
      <div class="cart-head">
        <h3>Build your stack</h3>
        <p>Pick a base layer, snap on the features you want, then send us your stack for a tailored quote.</p>
      </div>
      <div class="cart-body">
        <div class="cart-picks">
          <div class="pick-group">
            <span class="pick-label">1 — Choose your base layer</span>
            <div class="base-opts" id="baseOpts">
              <button class="opt-brick brick b-blue" data-id="one" data-label="One-Page" data-desc="a single high-converting landing page" data-benefit="One focused page built to turn visitors into customers."><span class="studs" aria-hidden="true"><i></i><i></i></span>One-Page</button>
              <button class="opt-brick brick b-pink" data-id="three" data-label="3-Page Site" data-desc="a three-page site with a blog you control" data-benefit="Room to tell your story across three pages, plus a blog."><span class="studs" aria-hidden="true"><i></i><i></i><i></i></span>3-Page Site</button>
              <button class="opt-brick brick b-orange" data-id="multi" data-label="Multi-Page" data-desc="a multi-page site built to rank" data-benefit="A full multi-page site engineered to rank and scale."><span class="studs" aria-hidden="true"><i></i><i></i><i></i><i></i></span>Multi-Page</button>
            </div>
          </div>
          <div class="pick-group">
            <span class="pick-label">2 — Add features</span>
            <div class="feat-opts" id="featOpts">
              <button class="opt-brick brick b-green" data-id="seo" data-label="SEO &amp; local search" data-benefit="Get found in local + maps search."><span class="studs" aria-hidden="true"><i></i><i></i></span>SEO &amp; local search</button>
              <button class="opt-brick brick b-red" data-id="social" data-label="Social media management" data-benefit="We post and manage your socials, on-brand."><span class="studs" aria-hidden="true"><i></i><i></i></span>Social media mgmt</button>
              <button class="opt-brick brick b-purple" data-id="gbp" data-label="Google Business setup" data-benefit="Optimized Google Business Profile + reviews."><span class="studs" aria-hidden="true"><i></i><i></i></span>Google Business</button>
              <button class="opt-brick brick b-pink" data-id="content" data-label="Content creation" data-benefit="Sharp copy and polished photos that sell."><span class="studs" aria-hidden="true"><i></i><i></i></span>Content creation</button>
              <button class="opt-brick brick b-teal" data-id="blog" data-label="Blog &amp; updates" data-benefit="A blog you control to keep customers coming back."><span class="studs" aria-hidden="true"><i></i><i></i></span>Blog &amp; updates</button>
              <button class="opt-brick brick b-orange" data-id="leads" data-label="Lead generation" data-benefit="Click-to-call, forms and booking wired to your inbox."><span class="studs" aria-hidden="true"><i></i><i></i></span>Lead generation</button>
              <button class="opt-brick brick b-blue" data-id="branding" data-label="Logo &amp; branding" data-benefit="A clean logo and color set for a consistent look."><span class="studs" aria-hidden="true"><i></i><i></i></span>Logo &amp; branding</button>
              <button class="opt-brick brick b-green" data-id="reviews" data-label="Review generation" data-benefit="Automated review requests to grow your reputation."><span class="studs" aria-hidden="true"><i></i><i></i></span>Review generation</button>
            </div>
          </div>
        </div>
        <div class="cart-stack-col">
          <span class="pick-label">Your stack</span>
          <div class="stack-zone" id="stackZone"></div>
          <div class="stack-desc" id="stackDesc"></div>
          <div class="stack-summary">
            <span class="stack-count" id="stackCount"></span>
            <a class="btn" id="requestQuote" href="#">Send my stack to sales</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  /* position the two floating bricks inside the CTA box */
  .cta .box :global(.floatbrick:nth-of-type(1)){top:24px;left:40px;transform:rotate(-12deg)}
  .cta .box :global(.floatbrick:nth-of-type(2)){bottom:26px;right:50px;transform:rotate(10deg)}
  .stak-col :global(.stak-base){min-width:300px;font-size:1.35rem}
</style>

<script>
  // Interactive "The Stak": click a block to read about it
  const panel = document.getElementById("stakText");
  const bricks = Array.from(document.querySelectorAll<HTMLElement>("#stakBricks .brick"));
  if (panel && bricks.length) {
    const COLORS: Record<string, string> = {
      "b-pink": "--pink", "b-purple": "--purple", "b-orange": "--orange",
      "b-green": "--green", "b-teal": "--teal", "b-red": "--red", "b-blue": "--blue",
    };
    const defaultHTML = panel.innerHTML;
    const reset = () => {
      bricks.forEach((b) => b.classList.remove("active"));
      panel.innerHTML = defaultHTML;
    };
    const show = (brick: HTMLElement) => {
      bricks.forEach((b) => b.classList.remove("active"));
      brick.classList.add("active");
      const title = brick.getAttribute("data-title") || "";
      const desc = brick.getAttribute("data-desc") || "";
      let token = "--ink";
      for (const c in COLORS) { if (brick.classList.contains(c)) { token = COLORS[c]; break; } }
      panel.innerHTML =
        '<div class="stak-tag" style="--c:var(' + token + ')">' + title + "</div>" +
        '<p class="stak-desc">' + desc + "</p>" +
        '<button class="stak-reset" type="button">← Back to overview</button>';
      panel.querySelector(".stak-reset")?.addEventListener("click", reset);
    };
    bricks.forEach((b) => {
      b.setAttribute("role", "button");
      b.setAttribute("tabindex", "0");
      b.addEventListener("click", () => show(b));
      b.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") { e.preventDefault(); show(b); }
      });
    });
  }

  // ── Build your stack (cart modal) ───────────────────────────────
  const overlay = document.getElementById("cartOverlay");
  const stackZone = document.getElementById("stackZone");
  const stackCount = document.getElementById("stackCount");
  const stackDesc = document.getElementById("stackDesc");
  const requestBtn = document.getElementById("requestQuote") as HTMLAnchorElement | null;
  const baseOpts = Array.from(document.querySelectorAll<HTMLButtonElement>("#baseOpts .opt-brick"));
  const featOpts = Array.from(document.querySelectorAll<HTMLButtonElement>("#featOpts .opt-brick"));
  if (overlay && stackZone && stackCount && stackDesc && requestBtn && baseOpts.length) {
    const SALES_EMAIL = "hello@sitestac.com";
    const colorOf = (el: Element) => (Array.from(el.classList).find((c) => c.startsWith("b-")) || "b-blue");
    const studsFor = (el: Element) => (el.querySelector(".studs")?.innerHTML) || "<i></i><i></i><i></i><i></i>";
    let base = baseOpts[0];

    function makeBrick(src: HTMLButtonElement, animate: boolean, isBase: boolean) {
      const el = document.createElement("span");
      el.className = "brick " + colorOf(src) + " stack-brick" + (animate ? " dropin" : "") + (isBase ? " stack-base" : "");
      el.dataset.id = src.dataset.id || "";
      el.innerHTML = '<span class="studs" aria-hidden="true">' + studsFor(src) + "</span>" + (src.dataset.label || "");
      if (animate) el.addEventListener("animationend", () => el.classList.remove("dropin"), { once: true });
      return el;
    }
    function renderBase() {
      const old = stackZone!.querySelector(".stack-base");
      const fresh = makeBrick(base, false, true);
      if (old) stackZone!.replaceChild(fresh, old);
      else stackZone!.appendChild(fresh); // column-reverse → first child sits at the bottom
    }
    function chosenFeats() { return featOpts.filter((f) => f.classList.contains("is-picked")); }

    function refresh() {
      const feats = chosenFeats();
      const total = feats.length + 1;
      stackCount!.textContent = total + (total === 1 ? " block" : " blocks");
      // description + benefits for this exact combination
      const intro = "<b>Your " + (base.dataset.label || "") + " stack</b> — " + (base.dataset.desc || "") +
        (feats.length ? ", plus " + feats.map((f) => (f.dataset.label || "").replace(/&amp;/g, "&").toLowerCase()).join(", ") + "." : ".");
      const CHK = '<span class="dot"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>';
      const benefits = [base, ...feats].map((b) => "<li>" + CHK + " " + (b.dataset.benefit || "") + "</li>").join("");
      stackDesc!.innerHTML = intro + "<ul>" + benefits + "</ul>";
      // mailto
      const lines = [(base.dataset.label || "") + " (base)", ...feats.map((f) => (f.dataset.label || "").replace(/&amp;/g, "&"))];
      const subject = "SiteStac quote — my stack (" + total + " blocks)";
      const body = "Hi SiteStac team,\n\nI built this stack and would like a quote / to speak with sales:\n\n" +
        lines.map((l) => "  • " + l).join("\n") + "\n\nName:\nBusiness:\nGoogle Business Profile link:\n\nThanks!";
      requestBtn!.href = "mailto:" + SALES_EMAIL + "?subject=" + encodeURIComponent(subject) + "&body=" + encodeURIComponent(body);
    }

    // base = single choice
    baseOpts.forEach((b) => b.addEventListener("click", () => {
      base = b;
      baseOpts.forEach((o) => o.classList.toggle("is-picked", o === b));
      baseOpts.forEach((o) => o.classList.toggle("is-off", o !== b));
      renderBase(); refresh();
    }));
    // features = multi toggle, each drops onto the stack
    featOpts.forEach((f) => f.addEventListener("click", () => {
      const on = f.classList.toggle("is-picked");
      if (on) {
        stackZone!.appendChild(makeBrick(f, true, false)); // append → lands on top (column-reverse)
      } else {
        stackZone!.querySelector('.stack-brick[data-id="' + f.dataset.id + '"]:not(.stack-base)')?.remove();
      }
      refresh();
    }));

    baseOpts[0].classList.add("is-picked");
    baseOpts.slice(1).forEach((o) => o.classList.add("is-off"));
    renderBase(); refresh();

    // open / close
    const open = () => { overlay.classList.add("open"); document.body.style.overflow = "hidden"; };
    const close = () => { overlay.classList.remove("open"); document.body.style.overflow = ""; };
    document.querySelectorAll<HTMLElement>(".cart-open").forEach((t) => t.addEventListener("click", (e) => { e.preventDefault(); open(); }));
    document.getElementById("cartClose")?.addEventListener("click", close);
    overlay.addEventListener("click", (e) => { if (e.target === overlay) close(); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
  }
</script>
